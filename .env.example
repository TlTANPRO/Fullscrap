# ============================================================
# Fullscrap — Environment Variables
# Copy file ini: cp .env.example .env
# ============================================================

# ── Provider 1: EnsembleData (TikTok + Instagram, berbayar tapi reliable) ──
# Daftar  : https://dashboard.ensembledata.com
# Harga   : Pay-per-use, ada free trial
# Gunakan : test-tiktok-ensemble.ts, test-instagram-ensemble.ts
ENSEMBLEDATA_API_TOKEN=your_ensembledata_token_here

# ── Provider 2, 3, 4: TikWM / Instagram Web API / yt-dlp ──
# Tidak butuh API key apapun — langsung bisa jalan.
# Test: npx ts-node examples/test-tikwm.ts
#       npx ts-node examples/test-instagram-web.ts
#       python src/python/ytdlp_instagram.py
