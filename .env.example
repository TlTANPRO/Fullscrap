# ============================================================
# Fullscrap — Environment Variables
# Copy file ini: cp .env.example .env
# ============================================================

# ── Provider 1: EnsembleData (TikTok + Instagram, berbayar tapi reliable) ──
# Daftar  : https://dashboard.ensembledata.com
# Harga   : Pay-per-use, ada free trial
# Gunakan : test-tiktok-ensemble.ts, test-instagram-ensemble.ts
ENSEMBLEDATA_API_TOKEN=your_ensembledata_token_here

# ── Provider 2, 3, 4: TikWM / Instagram Web API / yt-dlp ──
# Tidak butuh API key apapun — langsung bisa jalan.
# Test: npx ts-node examples/test-tikwm.ts
#       npx ts-node examples/test-instagram-web.ts
#       python src/python/ytdlp_instagram.py

# ── Provider 8: Perplexity via OpenRouter (TikTok + IG, via web search) ──────
# Daftar  : https://openrouter.ai → Settings → API Keys → Create Key
# Isi credits: https://openrouter.ai/settings/credits (minimal $5)
# Harga   : ~$0.001–0.01 per request (bukan gratis!)
# Model   : perplexity/sonar (murah), perplexity/sonar-pro (akurat)
# Gunakan : test-perplexity.ts
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Provider 9: Gemini + Google Search Grounding (TikTok + IG) ──────────────
# Daftar gratis: https://aistudio.google.com → Get API key
# Free tier   : ~15 req/menit, kuota harian terbatas
# Paid tier   : Lebih reliable, aktifkan billing di Google Cloud Console
# Model       : gemini-2.5-flash (dengan google_search tool)
# Gunakan     : test-gemini.ts
GEMINI_API_KEY=AIzaSy_your_key_here
