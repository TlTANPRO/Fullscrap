# ============================================================
# Fullscrap — Environment Variables
# Copy file ini menjadi .env dan isi dengan token masing-masing
# ============================================================

# PILIHAN 1: EnsembleData (Recommended)
# Daftar di: https://dashboard.ensembledata.com
ENSEMBLEDATA_API_TOKEN=your_ensembledata_token_here

# PILIHAN 2: RapidAPI
# Daftar di: https://rapidapi.com
# Subscribe: https://rapidapi.com/tikwm-tikwm-default/api/tiktok-scraper7
#        dan: https://rapidapi.com/dreaded_spin/api/instagram-scraper-api2
RAPIDAPI_KEY=your_rapidapi_key_here

# PILIHAN 3: Apify
# Daftar di: https://apify.com
APIFY_TOKEN=your_apify_token_here
