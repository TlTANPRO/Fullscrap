# ============================================================
# Fullscrap — Environment Variables
# Copy file ini menjadi .env dan isi token masing-masing provider
# ============================================================

# ── PILIHAN 1: EnsembleData (RECOMMENDED — TikTok + Instagram) ──
# Daftar : https://dashboard.ensembledata.com
# Harga  : Pay-per-use (murah), ada free trial
ENSEMBLEDATA_API_TOKEN=your_ensembledata_token_here

# ── PILIHAN 2: RapidAPI (TikTok + Instagram, beberapa provider) ──
# Subscribe masing-masing API di: https://rapidapi.com
# Satu RAPIDAPI_KEY berlaku untuk SEMUA RapidAPI provider
# TikTok  : tiktok-scraper7, tokapi-mobile-version, tiktok-api23
# Instagram: instagram-scraper-api2, instagram-looter2
RAPIDAPI_KEY=your_rapidapi_key_here

# ── PILIHAN 3: Apify (TikTok + Instagram, batch/massal) ──
# Daftar : https://apify.com ($5 kredit gratis/bulan)
APIFY_TOKEN=your_apify_token_here

# ── PILIHAN 5: HikerAPI (Instagram, 147 endpoints, 100 request gratis) ──
# Daftar : https://hikerapi.com/sign-up
# Harga  : $0.0006/request | 100 request GRATIS saat daftar
HIKERAPI_KEY=your_hikerapi_key_here

# ── PILIHAN 6: Instagram Graph API (Official — akun sendiri saja) ──
# Daftar : https://developers.facebook.com/apps/
# Token  : https://developers.facebook.com/tools/explorer/
# CATATAN: Hanya bisa akses data akun sendiri (Business/Creator)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_instagram_token
INSTAGRAM_USER_ID=your_numeric_instagram_user_id
INSTAGRAM_APP_ID=your_facebook_app_id
INSTAGRAM_APP_SECRET=your_facebook_app_secret

# ── PILIHAN 7: TikTok Research API (Official — riset akademik) ──
# Apply  : https://developers.tiktok.com/products/research-api/
# CATATAN: Harus apply dan disetujui tim TikTok (bisa beberapa minggu)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ── PILIHAN 8: instagrapi (Python — akun Instagram untuk login) ──
# Gunakan akun dummy/test, JANGAN akun utama
IG_USERNAME=your_dummy_instagram_username
IG_PASSWORD=your_dummy_instagram_password

# ── PILIHAN 9: TikTokApi Python (ms_token dari cookies tiktok.com) ──
# Cara dapat: F12 → Application → Cookies → tiktok.com → msToken
TIKTOK_MS_TOKEN=your_ms_token_from_browser_cookies
